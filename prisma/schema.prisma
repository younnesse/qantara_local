generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}


model Client {
  id                 String    @id @default(cuid())
  email              String    @unique
  name               String?
  password           String?
  phoneNumber        String?   @unique
  emailVerified      Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?
  isBanned           Boolean   @default(false)
  
  reviews            Review[]
}

model Provider {
  id                 String    @id @default(cuid())
  email              String    @unique
  name               String?
  password           String?
  phoneNumber        String?   @unique
  emailVerified      Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?
  isBanned           Boolean   @default(false)

  // Certificate & Identity Verification
  certificateStatus  String?
  identityStatus     String    @default("NOT_SUBMITTED")
  certificateMessage String?
  certificateIdHash  String?
  extractedFullName  String?
  extractedDate      String?
  yotiName           String?
  
  idCardImage             String?
  selfieImage             String?
  certificateImage        String?
  certificateId           String?
  verificationSubmittedAt DateTime?
  aiFaceMatch             Boolean?
  aiNameMatch             Boolean?
  aiAnalysisMessage       String?

  // NOUVEAUX CHAMPS — Catégorie professionnelle
  professionalCategoryId String?
  professionalCategory   ProfessionalCategory? @relation(fields: [professionalCategoryId], references: [id])

  // Catégorie 1 : Professions Libérales
  regulatoryBodyId       String?
  regulatoryBody         RegulatoryBody? @relation(fields: [regulatoryBodyId], references: [id])
  licenseNumber          String?         // Numéro d'inscription au tableau / ordre
  licenseDocumentUrl     String?         // URL du certificat/carte professionnelle uploadé
  licenseVerifiedAt      DateTime?       // Date de vérification
  licenseStatus          String          @default("PENDING") // PENDING, VERIFIED, REJECTED, EXPIRED
  licenseVerifiedBy      String?         // "GEMINI", "MANUAL", "API"
  licenseRejectionReason String?         // Raison si rejeté

  // Catégorie 2 : Artisans
  tradeId                String?
  trade                  Trade? @relation(fields: [tradeId], references: [id])
  cnamCardNumber         String?         // Numéro de Carte d'Artisan CNAM
  cnamCardDocumentUrl    String?         // URL de la carte uploadée
  cnamCardVerifiedAt     DateTime?
  cnamCardStatus         String          @default("PENDING")
  cnamCardVerifiedBy     String?
  cnamCardRejectionReason String?

  // Catégorie 3 : Auto-Entrepreneurs (NOUVEAU)
  autoEntrepreneurActivityId String?
  autoEntrepreneurActivity     AutoEntrepreneurActivity? @relation(fields: [autoEntrepreneurActivityId], references: [id])
  anaeCardNumber               String?         // Numéro de Carte d'Auto-Entrepreneur ANAE
  anaeCardDocumentUrl          String?         // URL de la carte ANAE uploadée
  anaeCardVerifiedAt           DateTime?
  anaeCardStatus               String          @default("PENDING")
  anaeCardVerifiedBy           String?
  anaeCardRejectionReason      String?

  // Profile Details
  title              String?
  category           String?
  bio                String?
  profileImage       String?
  location           String?
  portfolio          String?
  rating             Float     @default(0)
  reviewCount        Int       @default(0)
  isProfileComplete  Boolean   @default(false)

  // Relations
  services           Service[]
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}

model AuthorityCertificate {
  id           String   @id @default(cuid())
  certId       String   @unique
  holderName   String
  receivedDate DateTime
  category     String   // "doctors" | "programmer" | "translator"
  createdAt    DateTime @default(now())
}

model Service {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float?
  duration    Int?     // duration in minutes
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  rating      Float    @default(0)
  reviewCount Int      @default(0)

  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  
  reviews     Review[]
}

model Review {
  id          String   @id @default(cuid())
  rating      Int      // 1-5
  comment     String
  createdAt   DateTime @default(now())

  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model BannedEmail {
  email     String   @id
  reason    String?
  bannedAt  DateTime @default(now())
}

model VerificationToken {
  id         String   @id @default(cuid())
  email      String
  token      String   @unique
  expiresAt  DateTime
  
  @@unique([email, token])
}

model ProfessionalCategory {
  id          String   @id @default(cuid())
  name        String   // "regulated_profession", "artisan", "auto_entrepreneur"
  nameFr      String   // "Professions Libérales Réglementées"
  nameEn      String   // "Regulated Liberal Professions"
  nameAr      String   // "المهن الحرة المنظمة"
  description String?
  icon        String?  // Lucide icon name
  color       String   // "blue", "amber", "teal" — pour les badges UI
  order       Int      // Pour l'ordre d'affichage
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  regulatoryBodies RegulatoryBody[]
  trades           Trade[]
  autoEntrepreneurActivities AutoEntrepreneurActivity[]
  providers        Provider[]
}

model RegulatoryBody {
  id                String   @id @default(cuid())
  code              String   @unique // "CNOM", "CNOP", "UNBA", etc.
  name              String   // Nom complet
  nameFr            String
  nameEn            String
  nameAr            String
  categoryId        String
  category          ProfessionalCategory @relation(fields: [categoryId], references: [id])
  verificationUrl   String?  // URL du registre public si disponible
  requiresLicense   Boolean  @default(true)
  licenseLabel      String?  // "Numéro d'inscription au tableau"
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  providers Provider[]
}

model Trade {
  id           String   @id @default(cuid())
  name         String   // "electrician", "plumber", etc.
  nameFr       String   // "Électricien"
  nameEn       String   // "Electrician"
  nameAr       String   // "كهربائي"
  categoryId   String
  category     ProfessionalCategory @relation(fields: [categoryId], references: [id])
  cnamCode     String?  // Code CNAM du métier si disponible
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  providers Provider[]
}

model AutoEntrepreneurActivity {
  id          String   @id @default(cuid())
  name        String   // "web_development", "graphic_design", etc.
  nameFr      String   // "Développement Web"
  nameEn      String   // "Web Development"
  nameAr      String   // "تطوير الويب"
  categoryId  String
  category     ProfessionalCategory @relation(fields: [categoryId], references: [id])
  anaeCode    String?  // Code ANAE de l'activité si disponible
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  providers Provider[]
}
